# NODE_ENV=development
# DATABASE_URL=
# PORT=5016

# SUPER_ADMIN_PASSWORD=change-me-to-a-strong-password
# BCRYPT_SALT_ROUNDS=12

# JWT_ACCESS_SECRET="change-me-to-a-random-secret"
# JWT_REFRESH_SECRET="change-me-to-a-random-refresh-secret"
# JWT_ACCESS_EXPIRES_IN="1d"
# JWT_REFRESH_EXPIRES_IN="7d"

# # Email (Nodemailer - Gmail App Password)
# NODE_MAILER_EMAIL=
# NODE_MAILER_PASSWORD=

# # Brevo / Sendinblue (alternative to Nodemailer)
# BREVO_API_KEY=
# EMAIL=
# EMAIL_SENDER_NAME=

# BASE_URL_CLIENT="http://localhost:3000"
# BASE_URL_SERVER="http://localhost:5016"

# # Comma-separated list of allowed CORS origins (no spaces)
# CORS_ORIGINS="http://localhost:3000,http://localhost:3001,https://www.glassophite.com,https://glassophite.com"

# # DigitalOcean Spaces (or S3-compatible storage)
# DO_SPACE_ENDPOINT=
# DO_SPACE_ACCESS_KEY=
# DO_SPACE_SECRET_KEY=
# DO_SPACE_BUCKET=
# DO_SPACE_REGION=


# # Stripe
# STRIPE_PUBLISHED_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# # Firebase Admin SDK
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_CLIENT_ID=
# FIREBASE_CLIENT_CERT_URL=

# # SSL Commerz Payment Gateway (Bangladesh payments)
# # Sandbox (testing) — store_id=testbox, store_pass=testbox
# # Production — replace with your live credentials from sslcommerz.com
# SSL_STORE_ID=testbox
# SSL_STORE_PASS=testbox
# SSL_API_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
# SSL_VALIDATION_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
# SSL_CURRENCY=BDT
